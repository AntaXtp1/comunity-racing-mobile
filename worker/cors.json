{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://simrace-community.pages.dev",
          "http://localhost:5500",
          "http://127.0.0.1:5500"
        ],
        "methods": [
          "GET",
          "PUT",
          "HEAD"
        ],
        "headers": [
          "*"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
